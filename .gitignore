__pycache__/
*.pyc
.DS_Store

# Raw data and manuscript artifacts — local references only.
# The portal pulls fresh data straight from Dropbox via integrate_data.py,
# so none of these need to live in the repo (and the concatenated CSV is
# well over GitHub's 100 MB file limit anyway).
all_final_enhanced_all.csv
*_final_enhanced.txt
*_metadata.txt
# The Hub used to mirror NYU metadata INTO this public repo so /hub could serve
# it from GitHub Pages. The Hub is permission-gated now: its data lives in a
# private GCS bucket and is fetched through the auth service. Nothing Hub-related
# may be committed here again — the *_metadata.txt rule above already covers it,
# and these belt-and-braces rules cover the rest.
hub/data/
hub/data_js/

# PRIVATE in-house data must never reach this PUBLIC repo. `_inhouse_test/` holds
# real medulloblastoma peptides + assets pulled from the private bucket for local
# testing; a bare `git add -A` would have committed all of it (caught 2026-07-22).
_inhouse_test/
in-house/
# Editor/tool scratch files that accumulate at the repo root.
*.tmp.*
all_deepimmuno_immunogenicity.txt
US_HLA_frequency.csv
nature_cancer_submission_*.docx
cancer_discovery-*/
cancer_discovery-*.zip
dropbox.zip
